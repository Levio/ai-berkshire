AI_BERKSHIRE_ROOT=/app
AI_BERKSHIRE_VAR_DIR=/var/lib/ai-berkshire
CLAUDE_CLI=/usr/local/bin/claude
# 可选：透传给 Claude Code CLI 的 --model，例如 claude-opus-4-8、deepseek-chat、deepseek-reasoner
# CLAUDE_MODEL=claude-opus-4-8
AI_BERKSHIRE_JOB_TIMEOUT=1800
AI_BERKSHIRE_MAX_ARGUMENT_LENGTH=12000
AI_BERKSHIRE_PERMISSION_MODE=default
AI_BERKSHIRE_SKIP_PERMISSIONS=0

# 推荐服务器非交互部署使用 API key。复制本文件为 .env.docker 后填写。
# Anthropic 官方：
# ANTHROPIC_API_KEY=sk-ant-...

# Anthropic-compatible 网关 / 中转 / DeepSeek 兼容模式：
# 注意：该地址必须兼容 Anthropic Messages API；DeepSeek 官方 OpenAI-compatible API 不能保证直接可用。
# ANTHROPIC_API_KEY=你的_token
# ANTHROPIC_BASE_URL=https://你的_anthropic_兼容网关/v1
# CLAUDE_MODEL=deepseek-chat
# 或：CLAUDE_MODEL=deepseek-reasoner

# 如使用 Bedrock / Vertex，可按你的 Claude Code 配置开启。
# CLAUDE_CODE_USE_BEDROCK=1
# CLAUDE_CODE_USE_VERTEX=1
